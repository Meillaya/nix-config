// Niri configuration
// Docs: https://niri-wm.github.io/niri/

// ────────────── Input ──────────────
input {
    keyboard {
        xkb {
            layout "us"
        }
        numlock
    }

    touchpad {
        tap
        natural-scroll
    }

    focus-follows-mouse
    workspace-auto-back-and-forth

    // Force Super = Super explicitly. niri docs only specify defaults for "TTY"
    // (Super) and "nested winit window" (Alt) — for a regular Wayland session
    // the default is undocumented and may not be Super. Without this, all
    // Super+... binds are parsed (overlay displays them correctly) but never
    // match real keystrokes.
    mod-key "Super"
    mod-key-nested "Alt"
}

// ────────────── Outputs ──────────────
// Use `niri msg outputs` if these names ever change.
output "DP-1" {
    mode "3440x1440@143.975"
    scale 1
    position x=0 y=0
}

output "DP-2" {
    mode "1920x1080@144.001"
    scale 1
    position x=760 y=-1080
}

// ────────────── Workspaces ──────────────
// Using dynamic numeric workspaces only, so empty named workspaces do not clutter the bar.

// ────────────── Key Bindings ──────────────
binds {
    Super+SHIFT+ESCAPE { show-hotkey-overlay; }

    // ─── Launchers ───
    Super+RETURN hotkey-overlay-title="Open Terminal: Ghostty" { spawn-sh "ghostty"; }
    Super+SPACE hotkey-overlay-title="Open Launcher: Noctalia" { spawn-sh "noctalia msg panel-toggle launcher"; }
    Super+S hotkey-overlay-title="Open Control Center: Noctalia" { spawn-sh "noctalia msg panel-toggle control-center"; }
    Super+V hotkey-overlay-title="Open Clipboard History: Noctalia" { spawn-sh "noctalia msg panel-toggle clipboard"; }
    Super+B hotkey-overlay-title="Open Browser: Zen" { spawn-sh "zen"; }
    Super+E hotkey-overlay-title="Open Files: Dolphin" { spawn-sh "env QT_STYLE_OVERRIDE=kvantum QT_QUICK_CONTROLS_STYLE=org.kde.desktop XDG_MENU_PREFIX=plasma- GTK_THEME=Sweet-Dark GTK_USE_PORTAL=1 dolphin"; }
    Super+ALT+L hotkey-overlay-title="Lock Screen" { spawn-sh "noctalia msg screen-lock"; }

    // ─── Media / Audio ───
    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "noctalia msg volume-up"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "noctalia msg volume-down"; }
    XF86AudioMute allow-when-locked=true { spawn-sh "noctalia msg volume-mute"; }
    XF86AudioMicMute allow-when-locked=true { spawn-sh "noctalia msg mic-mute"; }
    XF86AudioNext allow-when-locked=true { spawn "playerctl" "next"; }
    XF86AudioPause allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPlay allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPrev allow-when-locked=true { spawn "playerctl" "previous"; }
    XF86MonBrightnessUp allow-when-locked=true { spawn-sh "noctalia msg brightness-up"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn-sh "noctalia msg brightness-down"; }

    // ─── Window Focus ───
    Super+Q hotkey-overlay-title=null allow-inhibiting=false { spawn-sh "$HOME/.local/bin/niri-close-window"; }
    Super+SHIFT+TAB hotkey-overlay-title="Previous Window" { focus-window-previous; }

    Super+LEFT  { focus-column-left; }
    Super+H     { focus-column-left; }
    Super+RIGHT { focus-column-right; }
    Super+L     { focus-column-right; }
    Super+UP    { focus-window-up; }
    Super+K     { focus-window-up; }
    Super+DOWN  { focus-window-down; }
    Super+J     { focus-window-down; }

    Super+CTRL+LEFT  { move-column-left; }
    Super+CTRL+H     { move-column-left; }
    Super+CTRL+RIGHT { move-column-right; }
    Super+CTRL+L     { move-column-right; }
    Super+CTRL+UP    { move-window-up; }
    Super+CTRL+K     { move-window-up; }
    Super+CTRL+DOWN  { move-window-down; }
    Super+CTRL+J     { move-window-down; }

    Super+HOME      { focus-column-first; }
    Super+END       { focus-column-last; }
    Super+CTRL+HOME { move-column-to-first; }
    Super+CTRL+END  { move-column-to-last; }

    Super+SHIFT+LEFT  { focus-monitor-left; }
    Super+SHIFT+RIGHT { focus-monitor-right; }
    Super+SHIFT+UP    { focus-monitor-up; }
    Super+SHIFT+DOWN  { focus-monitor-down; }

    Super+SHIFT+CTRL+LEFT  { move-column-to-monitor-left; }
    Super+SHIFT+CTRL+RIGHT { move-column-to-monitor-right; }
    Super+SHIFT+CTRL+UP    { move-column-to-monitor-up; }
    Super+SHIFT+CTRL+DOWN  { move-column-to-monitor-down; }

    // ─── Workspace Navigation ───
    Super+WHEELSCROLLDOWN cooldown-ms=150 { focus-workspace-down; }
    Super+WHEELSCROLLUP cooldown-ms=150 { focus-workspace-up; }
    Super+CTRL+WHEELSCROLLDOWN cooldown-ms=150 { move-column-to-workspace-down; }
    Super+CTRL+WHEELSCROLLUP cooldown-ms=150 { move-column-to-workspace-up; }

    Super+WHEELSCROLLRIGHT { focus-column-right; }
    Super+WHEELSCROLLLEFT { focus-column-left; }
    Super+CTRL+WHEELSCROLLRIGHT { move-column-right; }
    Super+CTRL+WHEELSCROLLLEFT { move-column-left; }

    Super+SHIFT+WHEELSCROLLDOWN { focus-column-right; }
    Super+SHIFT+WHEELSCROLLUP { focus-column-left; }
    Super+CTRL+SHIFT+WHEELSCROLLDOWN { move-column-right; }
    Super+CTRL+SHIFT+WHEELSCROLLUP { move-column-left; }

    Super+1 { focus-workspace 1; }
    Super+2 { focus-workspace 2; }
    Super+3 { focus-workspace 3; }
    Super+4 { focus-workspace 4; }
    Super+5 { focus-workspace 5; }
    Super+6 { focus-workspace 6; }
    Super+7 { focus-workspace 7; }
    Super+8 { focus-workspace 8; }
    Super+9 { focus-workspace 9; }

    Super+CTRL+1 { move-column-to-workspace 1; }
    Super+CTRL+2 { move-column-to-workspace 2; }
    Super+CTRL+3 { move-column-to-workspace 3; }
    Super+CTRL+4 { move-column-to-workspace 4; }
    Super+CTRL+5 { move-column-to-workspace 5; }
    Super+CTRL+6 { move-column-to-workspace 6; }
    Super+CTRL+7 { move-column-to-workspace 7; }
    Super+CTRL+8 { move-column-to-workspace 8; }
    Super+CTRL+9 { move-column-to-workspace 9; }

    Super+TAB { focus-workspace-previous; }

    // ─── Layout / Tiling Controls ───
    Super+CTRL+F hotkey-overlay-title="Expand Column" { expand-column-to-available-width; }
    Super+C hotkey-overlay-title="Center Column" { center-column; }
    Super+CTRL+C hotkey-overlay-title="Center Visible Columns" { center-visible-columns; }

    Super+MINUS { set-column-width "-10%"; }
    Super+EQUAL { set-column-width "+10%"; }
    Super+SHIFT+MINUS { set-window-height "-10%"; }
    Super+SHIFT+EQUAL { set-window-height "+10%"; }
    Super+CTRL+SHIFT+EQUAL hotkey-overlay-title="Reset Window Height" { reset-window-height; }

    // Fast horizontal / vertical layout cycling.
    Super+COMMA hotkey-overlay-title="Open Settings: Noctalia" { spawn-sh "noctalia msg settings-toggle"; }
    Super+ALT+COMMA hotkey-overlay-title="Previous Column Width Preset" { switch-preset-column-width-back; }
    Super+ALT+PERIOD hotkey-overlay-title="Next Column Width Preset" { switch-preset-column-width; }
    Super+SHIFT+COMMA hotkey-overlay-title="Previous Window Height Preset" { switch-preset-window-height-back; }
    Super+SHIFT+PERIOD hotkey-overlay-title="Next Window Height Preset" { switch-preset-window-height; }

    Super+ALT+LEFT { consume-or-expel-window-left; }
    Super+ALT+RIGHT { consume-or-expel-window-right; }
    Super+M hotkey-overlay-title="Maximize Column" { maximize-column; }
    Super+SHIFT+M hotkey-overlay-title="Maximize Window To Edges" { maximize-window-to-edges; }

    // ─── Window Modes ───
    Super+T hotkey-overlay-title="Toggle Floating" { toggle-window-floating; }
    Super+SHIFT+T hotkey-overlay-title="Switch Floating / Tiling Focus" { switch-focus-between-floating-and-tiling; }
    Super+F hotkey-overlay-title="Fullscreen" { fullscreen-window; }
    Super+SHIFT+F hotkey-overlay-title="Windowed Fullscreen" { toggle-windowed-fullscreen; }
    Super+W hotkey-overlay-title="Toggle Tabbed Column" { toggle-column-tabbed-display; }
    Super+G hotkey-overlay-title="Center Window" { center-window; }

    // ─── Screenshots ───
    CTRL+SHIFT+1 { screenshot; }
    CTRL+SHIFT+2 { screenshot-screen; }
    CTRL+SHIFT+3 { screenshot-window; }

    // ─── Recovery / Overview / Power ───
    Super+ESCAPE allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
    Super+O hotkey-overlay-title="Toggle Overview" repeat=false { toggle-overview; }
    Super+SHIFT+P hotkey-overlay-title="Power Off Monitors" { power-off-monitors; }
    CTRL+ALT+DELETE { quit; }
}

// ────────────── Startup / Misc ──────────────
spawn-sh-at-startup "if [ -n \"$WAYLAND_DISPLAY\" ] && [ -S /tmp/.X11-unix/X0 ]; then export DISPLAY=:0; fi; export QT_STYLE_OVERRIDE=kvantum QT_QUICK_CONTROLS_STYLE=org.kde.desktop XDG_MENU_PREFIX=plasma- GTK_THEME=Sweet-Dark GTK_USE_PORTAL=1; dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE XDG_RUNTIME_DIR PATH QT_STYLE_OVERRIDE QT_QUICK_CONTROLS_STYLE XDG_MENU_PREFIX GTK_THEME GTK_USE_PORTAL"
spawn-sh-at-startup "if command -v polkit-kde-authentication-agent-1 >/dev/null 2>&1; then polkit-kde-authentication-agent-1 & elif [ -x /usr/lib/polkit-kde-authentication-agent-1 ]; then /usr/lib/polkit-kde-authentication-agent-1 & fi"
spawn-sh-at-startup "xwayland-satellite"
spawn-sh-at-startup "if command -v awww-daemon >/dev/null 2>&1; then awww-daemon; elif command -v swww-daemon >/dev/null 2>&1; then swww-daemon; fi"
spawn-at-startup "noctalia"

prefer-no-csd
screenshot-path null

cursor {
    hide-when-typing
    hide-after-inactive-ms 1500
}

// ────────────── Layout ──────────────
layout {
    gaps 18
    center-focused-column "never"
    background-color "#120d16"

    preset-column-widths {
        proportion 0.34
        proportion 0.42
        proportion 0.50
        proportion 0.62
        proportion 0.74
    }

    default-column-width { proportion 0.50; }

    preset-window-heights {
        proportion 0.25
        proportion 0.33
        proportion 0.50
        proportion 0.66
        proportion 0.75
    }

    focus-ring {
        width 3
        active-gradient from="#f3a6c7" to="#d98cff" angle=135 relative-to="workspace-view" in="oklch longer hue"
        inactive-color "#4a3445"
        urgent-color "#ff7aa2"
    }

    border {
        width 1
        active-color "#5a4051"
        inactive-color "#251a24"
        urgent-color "#ff7aa2"
    }

    shadow {
        on
        softness 72
        spread 4
        offset x=0 y=18
        color "#160d1699"
        inactive-color "#10080f66"
    }

    tab-indicator {
        hide-when-single-tab
        place-within-column
        gap 6
        width 4
        length total-proportion=1.0
        position "top"
        gaps-between-tabs 6
        corner-radius 999
        active-gradient from="#f3a6c7" to="#cf89ff" angle=90 relative-to="workspace-view"
        inactive-color "#4a3445"
        urgent-color "#ff7aa2"
    }

    insert-hint {
        gradient from="#f3a6c799" to="#cf89ff99" angle=90 relative-to="workspace-view"
    }

    struts {}
}

// ────────────── Animations ──────────────
animations {
    workspace-switch {
        spring damping-ratio=1.0 stiffness=850 epsilon=0.0001
    }

    window-open {
        duration-ms 240
        curve "ease-out-expo"
    }

    window-close {
        duration-ms 180
        curve "ease-out-cubic"
    }

    horizontal-view-movement {
        spring damping-ratio=1.0 stiffness=760 epsilon=0.0001
    }

    window-movement {
        spring damping-ratio=1.0 stiffness=760 epsilon=0.0001
    }

    window-resize {
        spring damping-ratio=1.0 stiffness=900 epsilon=0.0001
    }

    config-notification-open-close {
        spring damping-ratio=0.65 stiffness=1200 epsilon=0.001
    }

    screenshot-ui-open {
        duration-ms 280
        curve "ease-out-quad"
    }

    overview-open-close {
        spring damping-ratio=0.95 stiffness=780 epsilon=0.0001
    }
}

// ────────────── Window Rules ──────────────
window-rule {
    match app-id=r#"^(zen|firefox)$"# title="^Picture-in-Picture$"
    open-floating true
}

window-rule {
    match app-id=r#"^(ghostty|com\.mitchellh\.ghostty)$"#
    default-column-width { proportion 0.50; }
}

window-rule {
    match app-id=r#"^org\.kde\.dolphin$"#
    default-column-width { proportion 0.50; }
}

window-rule {
    match title=r#"(Copying|Moving|Deleting|Trash|Emptying Trash|File Operation|Progress|Extracting|Compressing)"#
    open-floating true
    open-focused false
    default-column-width { fixed 520; }
}

window-rule {
    match app-id=r#"^obsidian$"#
    default-column-width { proportion 0.50; }
}

window-rule {
    match app-id="gamescope" title=r#"(?i)(trainer|cheat|fling)"#
    default-column-width { fixed 900; }
    default-window-height { fixed 720; }
}

window-rule {
    geometry-corner-radius 24
    clip-to-geometry true
}

window-rule {
    match app-id="dev.noctalia.Noctalia.Settings"
    open-floating true
    default-column-width { fixed 1080; }
    default-window-height { fixed 920; }
}

layer-rule {
    match namespace="^noctalia-backdrop"
    place-within-backdrop true
}

debug {
    // Allows notification actions and window activation from Noctalia.
    honor-xdg-activation-with-invalid-serial
}

// ────────────── Environment ──────────────
environment {
    DISPLAY ":1"
    ELECTRON_OZONE_PLATFORM_HINT "auto"
    QT_QPA_PLATFORM "wayland"
    QT_WAYLAND_DISABLE_WINDOWDECORATION "1"
    XDG_SESSION_TYPE "wayland"
    XDG_CURRENT_DESKTOP "niri"
    NOCTALIA_PAM_SERVICE "noctalia"
}

hotkey-overlay {
    skip-at-startup
    hide-not-bound
}
