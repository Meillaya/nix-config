# Ghostty loads built-in themes with the `theme` key.
# Verify available theme names with: ghostty +list-themes
theme = Catppuccin Mocha

# On Linux/GTK, make Ghostty's own window chrome follow the terminal theme
# instead of staying on the desktop/system theme.
window-theme = ghostty

# Start the declaratively selected login shell instead of ambient shell detection.
command = @NU_COMMAND@
