{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "kitty-direct",
    "source": "~/.config/fastfetch/snoopy-mugiwara.png",
    "width": 40,
    "height": 30,
    "padding": {
      "top": 2,
      "left": 2
    }
  },
  "display": {
    "separator": " ➜  ",
    "color": "white",
    "percent": {
      "type": 2
    },
    "key": {
      "width": 20
    }
  },
  "modules": [
    { "type": "custom", "format": "" },
    { "type": "custom", "format": "" },
    {
      "type": "datetime",
      "key": "󰃭  Date & Time",
      "format": "{1}/{3}/{11} - {14}:{17}",
      "keyColor": "cyan"
    },
    {
      "type": "command",
      "key": "󰖐  Current Weather",
      "text": "curl -s 'wttr.in/YOUR_LOCATION?format=%t' | xargs", // Change YOUR_LOCATION to your city
      "keyColor": "cyan"
    },
    "break",
    {
      "type": "os",
      "key": "󰣇 Distro",
      "keyColor": "blue"
    },
    {
      "type": "kernel",
      "key": " Kernel",
      "keyColor": "blue"
    },
    {
      "type": "de",
      "key": " DE",
      "keyColor": "blue"
    },
    {
      "type": "uptime",
      "key": "󱎫 Uptime",
      "keyColor": "blue"
    },
    "break",
    {
      "type": "cpu",
      "key": " CPU",
      "temp": true,
      "keyColor": "yellow"
    },
    {
      "type": "gpu",
      "key": "󰢮 GPU",
      "temp": true,
      "keyColor": "yellow"
    },
    {
      "type": "board",
      "key": "󰢮 Motherboard",
      "keyColor": "yellow"
    },
    {
      "type": "bios",
      "key": "󰾲 BIOS",
      "keyColor": "yellow"
    },
    {
      "type": "memory",
      "key": "󰍛 RAM",
      "keyColor": "yellow"
    },
    {
      "type": "command",
      "key": "󱛟 Storage Devices",
      "text": "lsblk -dno NAME,SIZE,MODEL | awk '$1 !~ /^zram/ { model=$0; sub(\"^[^[:space:]]+[[:space:]]+[^[:space:]]+[[:space:]]*\", \"\", model); printf \"%s%s %-7s %s\", (seen++ ? \"\\n\\033[80G\" : \"\"), $1, $2, model }'",
      "keyColor": "cyan"
    },
    "break",
    {
      "type": "disk",
      "key": "󱛟 Disk Usage",
      "folders": "",
      "showRegular": true,
      "showExternal": true,
      "showHidden": false,
      "showSubvolumes": false,
      "showReadOnly": true,
      "showUnknown": true,
      "keyColor": "cyan"
    },
    "break",
    {
      "type": "display",
      "key": "󰍹 Monitor",
      "keyColor": "green"
    },
    {
      "type": "shell",
      "key": "󱆃 Shell",
      "keyColor": "green"
    },
    {
      "type": "terminal",
      "key": " Terminal",
      "keyColor": "green"
    },
    {
      "type": "terminalfont",
      "key": " Font",
      "keyColor": "green"
    },
    "break",
    {
      "type": "localip",
      "key": "󰈀 Ethernet",
      "showIpv4": true,
      "keyColor": "white"
    },
    {
      "type": "wifi",
      "key": " WiFi",
      "keyColor": "white"
    },
    {
      "type": "bluetooth",
      "key": " Bluetooth",
      "keyColor": "white"
    },
    "break",
    {
      "type": "sound",
      "key": "󱍚 Audio Device",
      "keyColor": "red"
    },
    {
      "type": "media",
      "key": "󰝚 Listening To",
      "format": "{3} ➜ {1}",
      "keyColor": "red"
    },
    "break",
    {
      "type": "colors",
      "key": " Colors",
      "symbol": "circle"
    }
  ]
}
