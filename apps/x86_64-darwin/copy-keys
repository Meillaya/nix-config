#!/usr/bin/env bash
set -euo pipefail

red='\033[0;31m'
green='\033[0;32m'
reset='\033[0m'

username=${USER:?USER is not set}
ssh_dir="/Users/${username}/.ssh"
mount_path=""

handle_no_usb() {
  printf '%b\n' "${red}No USB drive found or mounted.${reset}"
  printf '%b\n' "${green}Generate new SSH keys if no backup drive is available.${reset}"
  exit 1
}

mount_usb() {
  local dev
  while IFS= read -r dev; do
    mount_path=$(diskutil info "/dev/${dev}" | awk -F: '/Mount Point/ { sub(/^[[:space:]]+/, "", $2); print $2; exit }')
    if [[ -n "$mount_path" && "$mount_path" != "Not mounted" ]]; then
      printf '%b\n' "${green}USB drive found at ${mount_path}.${reset}"
      return
    fi
  done < <(diskutil list external physical | awk '/^[[:space:]]*[0-9]+:/ { print $NF }')
}

install_key() {
  local source=$1
  local destination=$2
  local mode=$3
  install -m "$mode" "${mount_path}/${source}" "${ssh_dir}/${destination}"
}

install -d -m 0700 "$ssh_dir"
mount_usb
[[ -n "$mount_path" ]] || handle_no_usb

install_key id_ed25519_github id_ed25519 600
install_key id_ed25519_github.pub id_ed25519.pub 644
install_key id_ed25519_agenix id_ed25519_agenix 600
install_key id_ed25519_agenix.pub id_ed25519_agenix.pub 644
chown "${username}:staff" \
  "$ssh_dir/id_ed25519" \
  "$ssh_dir/id_ed25519.pub" \
  "$ssh_dir/id_ed25519_agenix" \
  "$ssh_dir/id_ed25519_agenix.pub"
