#!/usr/bin/env bash
set -euo pipefail

green='\033[1;32m'
yellow='\033[1;33m'
red='\033[1;31m'
reset='\033[0m'

if [[ ${1:-} == "--help" || ${1:-} == "-h" ]]; then
  cat <<'EOF'
Usage: clean

Deletes system generations older than seven days, then refreshes the current
architecture's bootloader configuration.
EOF
  exit 0
fi

if (( $# > 0 )); then
  printf '%b\n' "${red}Unexpected argument: $1${reset}" >&2
  exit 2
fi

case "$(uname -m)" in
  x86_64) flake_target="x86_64-linux" ;;
  aarch64) flake_target="aarch64-linux" ;;
  *)
    printf '%b\n' "${red}Unsupported architecture: $(uname -m)${reset}" >&2
    exit 1
    ;;
esac

printf '%b\n' "${yellow}Removing system generations older than seven days...${reset}"
sudo nix-collect-garbage --delete-older-than 7d

printf '%b\n' "${yellow}Refreshing the ${flake_target} bootloader configuration...${reset}"
sudo nixos-rebuild boot --flake ".#${flake_target}" --install-bootloader

printf '%b\n' "${green}Cleanup complete.${reset}"
printf '%b\n' "${yellow}Boot partition status:${reset}"
df -h /boot
