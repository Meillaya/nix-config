#!/usr/bin/env bash
set -euo pipefail

red='\033[1;31m'
green='\033[1;32m'
yellow='\033[1;33m'
reset='\033[0m'

host=""
rebuild_args=()

while (( $# > 0 )); do
  case "$1" in
    --host=*)
      host=${1#*=}
      shift
      ;;
    --host)
      if (( $# < 2 )); then
        printf '%b\n' "${red}--host requires a value${reset}" >&2
        exit 2
      fi
      host=$2
      shift 2
      ;;
    --help|-h)
      cat <<'EOF'
Usage: build-switch [--host HOST] [nixos-rebuild arguments...]

Defaults to the enrolled x86 workstation output, x86_64-linux.
EOF
      exit 0
      ;;
    *)
      rebuild_args+=("$1")
      shift
      ;;
  esac
done

if [[ -n "$host" ]]; then
  flake_target=$host
  printf '%b\n' "${yellow}Building named host: ${host}${reset}"
else
  case "$(uname -m)" in
    x86_64) flake_target="x86_64-linux" ;;
    *)
      printf '%b\n' "${red}Deployment is supported only for enrolled x86_64 hosts${reset}" >&2
      exit 1
      ;;
  esac
  printf '%b\n' "${yellow}Building platform: ${flake_target}${reset}"
fi

case "$flake_target" in
  x86_64-linux) ;;
  *)
    printf '%b\n' "${red}Deployment denied for non-release or evaluation host: ${flake_target}${reset}" >&2
    exit 1
    ;;
esac

printf '%b\n' "${yellow}Starting...${reset}"

# Pass the user's agent socket to root so private flake inputs remain available.
sudo env SSH_AUTH_SOCK="${SSH_AUTH_SOCK:-}" \
  /run/current-system/sw/bin/nixos-rebuild switch \
  --flake ".#${flake_target}" \
  "${rebuild_args[@]}"

printf '%b\n' "${green}Switch complete.${reset}"
